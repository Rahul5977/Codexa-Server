generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  STUDENT
  TEACHER
  ADMIN
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  DELETED
}

enum SubmissionStatus {
  PENDING
  PROCESSING
  ACCEPTED
  WRONG_ANSWER
  ERROR
  TIME_LIMIT_EXCEEDED
  MEMORY_LIMIT_EXCEEDED
  COMPILATION_ERROR
}

model User {
  id       String        @id @default(uuid())
  name     String
  email    String        @unique
  password String
  role     Role          @default(USER)
  status   AccountStatus @default(ACTIVE)

  image_url        String?
  imageUrlPublicId String?
  bio              String?

  emailVerified Boolean @default(false)
  refreshToken  String?

  currentRating Float @default(0)
  totalSolved   Int   @default(0)
  easyCount     Int   @default(0)
  mediumCount   Int   @default(0)
  hardCount     Int   @default(0)

  githubUrl   String?
  linkedinUrl String?

  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  submissions   Submission[]
  userAnalytics UserAnalytics?
  topicAttempts TopicAttempt[]

  // Classroom relations
  studentEnrollments ClassroomEnrollment[] @relation("ClassroomStudent")
  ownedClassrooms    Classroom[]           @relation("ClassroomTeacher")

  // Assignment/Exam submissions
  assignmentSubmissions AssignmentSubmission[]
  examSubmissions       ExamSubmission[]
  assignmentDrafts      AssignmentDraft[]
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

model Problem {
  id          String     @id @default(uuid())
  title       String
  difficulty  Difficulty
  statement   String
  examples    Json[]
  constraints String[]
  tags        String[]
  hints       String[]
  companies   String[]
  testcases   Json[]                 // Visible test cases (shown to user for "Run")
  hiddenTestcases Json[]  @default([]) // Hidden test cases (used for "Submit")
  
  // Function metadata for code execution
  functionName String                 // e.g., "twoSum", "isValid"
  parameters   Json                   // Array of {name, type}, e.g., [{"name": "nums", "type": "int[]"}]
  returnType   String                 // e.g., "int[]", "boolean", "ListNode"
  codeStubs    Json?                  // Language-specific starter code (optional)
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Relations
  submissions        Submission[]
  problemAnalytics   ProblemAnalytics?
  assignmentProblems AssignmentProblem[]
  examProblems       ExamProblem[]
  assignmentDrafts   AssignmentDraft[]
}

model Submission {
  id         String  @id @default(uuid())
  userId     String
  problemId  String
  code       String  @db.Text
  languageId Int
  language   String? // e.g. "python", "cpp", "java"

  // Status
  status SubmissionStatus @default(PENDING)

  // Result from judge0
  stdout String? @db.Text
  stderr String? @db.Text
  time   String? // execution time from judge0
  memory Int? // memory in KB

  // Analytics fields
  executionTimeMs Float? // parsed numeric execution time in ms
  attemptNumber   Int    @default(1) // which attempt is this for this user+problem

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user    User    @relation(fields: [userId], references: [id])
  problem Problem @relation(fields: [problemId], references: [id])

  @@index([userId])
  @@index([problemId])
  @@index([status])
  @@index([userId, problemId])
  @@map("submissions")
}

model UserAnalytics {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  // Basic Stats
  totalSolved    Int @default(0)
  totalAttempted Int @default(0)
  easySolved     Int @default(0)
  mediumSolved   Int @default(0)
  hardSolved     Int @default(0)

  // Streak Stats
  streakCurrent Int       @default(0)
  streakMax     Int       @default(0)
  lastActive    DateTime?

  // Performance (JSON for flexibility)
  // e.g. { "Graph": { "solved": 5, "attempted": 8, "strength": 0.72 }, ... }
  topicStrength Json?

  // Activity Heatmap (Year-Month-Day mapped to count)
  // e.g. { "2024-01-01": 5, "2024-01-02": 1 }
  activityLog Json?

  // Efficiency: average execution time percentile per language
  // e.g. { "python": { "avgTime": 120, "percentile": 65 }, ... }
  efficiencyStats Json?

  // Language distribution
  // e.g. { "python": 40, "cpp": 20, "java": 10 }
  languageStats Json?

  updatedAt DateTime @updatedAt

  @@map("user_analytics")
}

// Granular per-topic tracking for radar chart
model TopicAttempt {
  id        String @id @default(uuid())
  userId    String
  user      User   @relation(fields: [userId], references: [id])
  topic     String
  solved    Int    @default(0)
  attempted Int    @default(0)
  // Difficulty-weighted strength: solved/attempted * difficultyWeight
  strength  Float  @default(0)

  // Track per-difficulty within topic
  easySolved   Int @default(0)
  mediumSolved Int @default(0)
  hardSolved   Int @default(0)

  updatedAt DateTime @updatedAt

  @@unique([userId, topic])
  @@index([userId])
  @@map("topic_attempts")
}

// Track global difficulty stats per problem
model ProblemAnalytics {
  id            String  @id @default(uuid())
  problemId     String  @unique
  problem       Problem @relation(fields: [problemId], references: [id])
  totalAttempts Int     @default(0)
  totalSolved   Int     @default(0)
  avgTimeMs     Float? // Average execution time in ms
  avgMemory     Int? // Average memory in KB

  // Per-language avg execution time
  // e.g. { "python": { "avgTime": 150, "count": 30 }, "cpp": { "avgTime": 20, "count": 50 } }
  languageAvgTime Json?

  updatedAt DateTime @updatedAt

  @@map("problem_analytics")
}

// Classroom/Course Models
model Classroom {
  id        String @id @default(uuid())
  name      String
  code      String @unique // 6-character random course code
  teacherId String
  teacher   User   @relation("ClassroomTeacher", fields: [teacherId], references: [id])

  description String?
  imageUrl    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  enrollments ClassroomEnrollment[]
  assignments Assignment[]
  exams       Exam[]

  @@index([teacherId])
  @@index([code])
  @@map("classrooms")
}

model ClassroomEnrollment {
  id          String @id @default(uuid())
  classroomId String
  studentId   String

  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  student   User      @relation("ClassroomStudent", fields: [studentId], references: [id])

  joinedAt DateTime @default(now())

  @@unique([classroomId, studentId]) // A student can only enroll once per classroom
  @@index([classroomId])
  @@index([studentId])
  @@map("classroom_enrollments")
}

// Assignment and Exam Models
model Assignment {
  id          String   @id @default(uuid())
  title       String
  subtitle    String?
  description String?
  deadline    DateTime

  classroomId String
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  problems    AssignmentProblem[]
  submissions AssignmentSubmission[]
  drafts      AssignmentDraft[]

  @@index([classroomId])
  @@index([deadline])
  @@map("assignments")
}

model AssignmentProblem {
  id           String @id @default(uuid())
  assignmentId String
  problemId    String
  order        Int // Order of problem in the assignment (1, 2, 3, etc.)

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  problem    Problem    @relation(fields: [problemId], references: [id])

  @@unique([assignmentId, problemId]) // A problem can only be added once per assignment
  @@unique([assignmentId, order]) // Each order position is unique within assignment
  @@index([assignmentId])
  @@map("assignment_problems")
}

model AssignmentSubmission {
  id           String @id @default(uuid())
  assignmentId String
  studentId    String

  // JSON containing solutions for each problem
  // Structure: { "problemId1": { "code": "...", "language": "python" }, ... }
  solutions Json

  // Grading fields
  grade    Int?    // 0-100, null if not graded yet
  feedback String? // Teacher's feedback

  submittedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student    User       @relation(fields: [studentId], references: [id])

  @@unique([assignmentId, studentId]) // A student can only submit once per assignment
  @@index([assignmentId])
  @@index([studentId])
  @@map("assignment_submissions")
}

model AssignmentDraft {
  id           String @id @default(uuid())
  assignmentId String
  studentId    String
  problemId    String

  code       String
  languageId Int    @default(71) // Judge0 language ID

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student    User       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  problem    Problem    @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, studentId, problemId]) // Only one draft per student per problem per assignment
  @@index([assignmentId])
  @@index([studentId])
  @@index([problemId])
  @@map("assignment_drafts")
}

model Exam {
  id          String   @id @default(uuid())
  title       String
  subtitle    String?
  description String?
  startTime   DateTime // When exam becomes available to start
  duration    Int      // Duration in minutes (required)

  classroomId String
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  problems    ExamProblem[]
  submissions ExamSubmission[]

  @@index([classroomId])
  @@index([startTime])
  @@map("exams")
}

model ExamProblem {
  id        String @id @default(uuid())
  examId    String
  problemId String
  order     Int // Order of problem in the exam (1, 2, 3, etc.)

  exam    Exam    @relation(fields: [examId], references: [id], onDelete: Cascade)
  problem Problem @relation(fields: [problemId], references: [id])

  @@unique([examId, problemId]) // A problem can only be added once per exam
  @@unique([examId, order]) // Each order position is unique within exam
  @@index([examId])
  @@map("exam_problems")
}

model ExamSubmission {
  id        String @id @default(uuid())
  examId    String
  studentId String

  // JSON containing solutions for each problem
  // Structure: { "problemId1": { "code": "...", "language": "python" }, ... }
  solutions Json @default("{}")

  // Exam timing
  startedAt   DateTime  @default(now()) // When student started the exam
  submittedAt DateTime? // When student submitted (null if auto-submitted)
  finishedAt  DateTime? // When exam ended (submitted or timed out)

  // Grading fields
  grade    Int?    // 0-100, null if not graded yet
  feedback String? // Teacher's feedback

  // Proctoring fields
  proctoringViolations Json?   @default("[]") // Array of violation events
  tabSwitchCount       Int     @default(0)    // Number of tab switches
  fullscreenExitCount  Int     @default(0)    // Number of fullscreen exits
  warningCount         Int     @default(0)    // Total warnings issued
  autoSubmitted        Boolean @default(false) // Whether exam was auto-submitted due to violations

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  exam    Exam @relation(fields: [examId], references: [id], onDelete: Cascade)
  student User @relation(fields: [studentId], references: [id])

  @@unique([examId, studentId]) // A student can only submit once per exam
  @@index([examId])
  @@index([studentId])
  @@map("exam_submissions")
}