NODE_ENV=development
PORT=3005
DATABASE_URL=your-database-url-here

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT (for auth middleware if needed)
JWT_ACCESS_SECRET=your-access-secret-key

# CORS
CORS_ORIGIN=http://localhost:5173

# Google Gemini AI (required for AI analysis feature)
GEMINI_API_KEY=your-gemini-api-key-here

# How long to cache AI analysis results in Redis (seconds). Default: 7 days
AI_ANALYSIS_TTL=604800
